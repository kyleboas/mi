# Persistent Flue orchestrator. Optional; if unset, Mi uses the safe pi-backed fallback path.
FLUE_ENABLED=true
# Optional command/path. If empty, the adapter uses ./node_modules/.bin/flue when present, then PATH flue.
FLUE_CMD=
# Per-request Flue timeout in milliseconds.
FLUE_TIMEOUT_MS=30000
# Stable Flue conversation/session id for normal chat.
FLUE_CHAT_SESSION=mi-chat

# pi command and default models for chat fallback, read-only inspection, and workers.
PI_CMD=pi
PI_MODEL=openai-codex/gpt-5.5:low
PI_WORKER_MODEL=openai-codex/gpt-5.5:low

# Disabled by default because repair workers may edit files, create branches, run tests, and prepare PRs.
# Enable only behind approval gates.
PI_REPAIR_ENABLED=false

# Long-running local Flue server for persistent chat orchestration.
FLUE_URL=http://127.0.0.1:3583
FLUE_HOST=127.0.0.1
FLUE_PORT=3583

# Optional Pushover notifications. Leave blank to disable.
PUSHOVER_USER=
PUSHOVER_TOKEN=
