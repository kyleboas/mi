# Optional. If unset, Pushover notifications are skipped.
PUSHOVER_USER=
PUSHOVER_TOKEN=

# Bind to 127.0.0.1 for a private-network reverse proxy, or to a private interface for direct private-network HTTP fallback.
# Do not bind Mi to a public interface.
HOST=127.0.0.1
PORT=8787

# Mi control surface is private-network-only by default.
# Allowed remote clients: loopback, private-network ranges, or explicit PRIVATE_ALLOWED_IPS.
REQUIRE_PRIVATE_NETWORK=true
PRIVATE_ALLOWED_IPS=

# Required app password/token for web login and Bearer API auth.
ASSISTANT_TOKEN=

# Persistent Flue orchestrator. It must bind to loopback and be reached through Mi's private-network-only web app.
# FLUE_ENABLED=false routes normal chat through the safe pi-backed fallback path.
FLUE_ENABLED=true
# Optional command/path. If empty, the adapter uses ./node_modules/.bin/flue when present, then PATH flue.
FLUE_CMD=
# Per-request Flue timeout in milliseconds.
FLUE_TIMEOUT_MS=30000
# Stable Flue conversation/session id for normal chat.
FLUE_CHAT_SESSION=mi-chat

# pi command. Override when your pi binary is not on PATH.
PI_CMD=pi

# Default pi model for chat fallback, read-only inspection, and workers.
PI_MODEL=openai-codex/gpt-5.5:low
PI_WORKER_MODEL=openai-codex/gpt-5.5:low

# Disabled by default because repair workers may edit files, create branches, run tests, and prepare PRs.
# Enable only behind approval gates.
PI_REPAIR_ENABLED=false

# Long-running local Flue server for persistent chat orchestration.
FLUE_URL=http://127.0.0.1:3583
FLUE_HOST=127.0.0.1
FLUE_PORT=3583
